# =============================================================================
# Spatial-LLaVA .gitignore
# =============================================================================

# ── LARGE MODEL/DATA FILES ───────────────────────────────────────────────────
*.pth
*.pt
*.safetensors
*.bin
*.onnx
*.h5

# ── DATA ─────────────────────────────────────────────────────────────────────
# Keep pkl (small, important for reproducibility)
data/coco/
data/*.zip

# ── WEIGHTS / HF CACHE ───────────────────────────────────────────────────────
weights/
.cache/
hf_cache/
transformers_cache/

# ── CHECKPOINTS (large, not tracked) ─────────────────────────────────────────
checkpoints/

# ── RESULTS (tracked, important) ─────────────────────────────────────────────
# Track metrics and predictions
# Ignore example PNGs (too many, regenerable)
results/baseline/examples/
results/main/examples/
results/ablation/examples/
results/coursework/examples/
results/enterprise/examples/

# ── LOGS (not tracked) ───────────────────────────────────────────────────────
nohup.out

# ── PYTHON ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── TESTING ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── JUPYTER ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── VIRTUAL ENVIRONMENTS ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── ENVIRONMENT FILES ────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
*.code-workspace
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── TEMP / BACKUP ────────────────────────────────────────────────────────────
*.bak
*.backup
*.tmp
*.temp
*.tar.gz
*.zip
*.rar
*.7z

# ── DOCKER ───────────────────────────────────────────────────────────────────
.dockerignore
docker-volumes/

# ── MISC ─────────────────────────────────────────────────────────────────────
For_Myself.md
node_modules/

