# ── Large files (never commit these) ──────────────────────
*.pkl
*.pth
*.pt
*.safetensors
*.bin

# ── Data directory (keep folder, ignore contents) ──────────
data/*
!data/.gitkeep

# ── Checkpoints (keep folders, ignore contents) ────────────
checkpoints/*
!checkpoints/.gitkeep
!checkpoints/coursework/
!checkpoints/coursework/.gitkeep
!checkpoints/enterprise/
!checkpoints/enterprise/.gitkeep

# ── Results (keep folders, ignore contents) ────────────────
results/*
!results/.gitkeep
!results/coursework/
!results/coursework/.gitkeep
!results/enterprise/
!results/enterprise/.gitkeep

# ── Logs (keep folder, ignore contents) ────────────────────
logs/*
!logs/.gitkeep
*.log
nohup.out

# ── HuggingFace cache ──────────────────────────────────────
.cache/
hf_cache/

# ── Python ─────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ────────────────────────────────────
.venv/
venv/
env/

# ── Jupyter ─────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Docker ──────────────────────────────────────────────────
.dockerignore

# ── Environment variables ───────────────────────────────────
.env
.env.local

# ── OS files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── IDE ─────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project.coverage
