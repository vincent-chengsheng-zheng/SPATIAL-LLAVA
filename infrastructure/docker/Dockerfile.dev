# infrastructure/docker/Dockerfile.dev
#
# PURPOSE : Local development on Mac (CPU-only)
# USE FOR : Writing code, running unit tests, debugging logic
# NOT FOR : Actual model training (use SUTD cluster for that)
#           Jupyter / Gradio / TensorBoard (not needed locally)
#
# Compatible with: Mac Intel + Mac Apple Silicon (M1/M2/M3)
# Build time     : ~5 minutes
# Image size     : ~2 GB

# ── Base image ────────────────────────────────────────────────────────────────
# Using plain Python slim instead of pytorch/pytorch because the official
# PyTorch Docker images do NOT support Mac ARM (Apple Silicon).
# We install PyTorch CPU-only manually below.
FROM python:3.10-slim

WORKDIR /workspace

# ── System dependencies ───────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    git \
    wget \
    curl \
    vim \
    build-essential \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# ── Python dependencies ───────────────────────────────────────────────────────
# Step 1: Copy requirements first (Docker cache optimization)
#         If requirements.txt doesn't change, this layer is reused on rebuild.
COPY requirements.txt /tmp/requirements.txt

# Step 2: Install PyTorch CPU-only
#         --index-url points to CPU wheels (no CUDA, much smaller)
#         torch/torchvision must NOT be in requirements.txt
RUN pip install --upgrade pip && \
    pip install \
        torch==2.0.1 \
        torchvision==0.15.2 \
        --index-url https://download.pytorch.org/whl/cpu \
        --no-cache-dir

# Step 3: Install remaining project dependencies
#         (torch already installed above, pip will skip it if version matches)
RUN pip install -r /tmp/requirements.txt --no-cache-dir

# ── Entrypoint ────────────────────────────────────────────────────────────────
# Keep container alive in background.
# To get a shell: docker compose exec dev bash
# To run tests:   docker compose exec dev python -m pytest tests/
CMD ["tail", "-f", "/dev/null"]